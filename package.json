    "demo": "node scripts/demo-flow.js",
    "verify": "npm test && npm run check && npm run demo"
  },
  "devDependencies": {
    "miniprogram-api-typings": "latest",
    "typescript": "latest"
  },
  "engines": { "node": ">=22" }
}
