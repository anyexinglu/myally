{
  "name": "myally-miniapp-poc",
  "version": "0.1.0",
  "private": true,
  "description": "我在 MyAlly｜个人AI助理微信小程序POC",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "typecheck": "tsc -p miniprogram/tsconfig.json --noEmit",
    "check": "node scripts/validate-project.js && npm run typecheck",
    "demo": "node scripts/demo-flow.js",
    "demo:agent": "node scripts/hermes-lite-demo.js",
    "cloud:check": "node scripts/cloudbase-readiness.js",
    "cloud:deploy": "node scripts/cloudbase-readiness.js --deploy",
    "verify": "npm test && npm run check && npm run demo && npm run demo:agent"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.6.0",
    "miniprogram-api-typings": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=22"
  }
}
