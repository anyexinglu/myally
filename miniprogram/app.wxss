page {
  background: #f7faf9;
  color: #17211e;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}

button::after { border: 0; }

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 34rpx 32rpx calc(188rpx + env(safe-area-inset-bottom));
}

.page-head { margin: 8rpx 4rpx 32rpx; }
.eyebrow { display: block; color: #33a981; font-size: 22rpx; font-weight: 650; letter-spacing: 2rpx; margin-bottom: 10rpx; }
.page-title { display: block; color: #17211e; font-size: 46rpx; font-weight: 750; letter-spacing: -1rpx; line-height: 1.25; }
.page-subtitle { display: block; color: #77837f; font-size: 25rpx; line-height: 1.6; margin-top: 10rpx; }

.card {
  background: #ffffff;
  border: 1rpx solid #edf2f0;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 40rpx rgba(34, 83, 68, .045);
  box-sizing: border-box;
  margin-bottom: 22rpx;
  padding: 28rpx;
}

.section-title { color: #1d2925; font-size: 29rpx; font-weight: 680; line-height: 1.45; }
.row { display: flex; align-items: center; gap: 16rpx; }
.between { justify-content: space-between; }
.hint { color: #8a9692; font-size: 23rpx; line-height: 1.55; }
.error { color: #b94b4b; }

.tag {
  display: inline-flex;
  align-items: center;
  background: #e9f8f2;
  border-radius: 999rpx;
  color: #278f6c;
  font-size: 21rpx;
  font-weight: 650;
  line-height: 1;
  padding: 9rpx 16rpx;
}

.primary {
  background: #4ecfa5 !important;
  border-radius: 999rpx !important;
  box-shadow: 0 12rpx 28rpx rgba(78, 207, 165, .22);
  color: #ffffff !important;
  font-size: 28rpx !important;
  font-weight: 680;
  line-height: 92rpx !important;
}

.primary[disabled] { opacity: .62; }
.secondary { background: #e9f8f2 !important; border-radius: 999rpx !important; color: #278f6c !important; }
.input, .textarea { background: #f5f8f7; border-radius: 22rpx; box-sizing: border-box; width: 100%; }

.bottom-nav {
  align-items: center;
  background: rgba(255, 255, 255, .97);
  border: 1rpx solid #e5efeb;
  border-radius: 999rpx;
  bottom: calc(22rpx + env(safe-area-inset-bottom));
  box-shadow: 0 16rpx 52rpx rgba(25, 73, 57, .11);
  display: flex;
  height: 104rpx;
  justify-content: space-between;
  left: 32rpx;
  padding: 8rpx;
  position: fixed;
  right: 32rpx;
  z-index: 50;
}

.nav-item {
  align-items: center;
  border-radius: 999rpx;
  color: #6f7a76;
  display: flex;
  flex: 1;
  flex-direction: column;
  font-size: 20rpx;
  gap: 2rpx;
  height: 88rpx;
  justify-content: center;
}

.nav-item.active { background: #4ecfa5; color: #ffffff; }
.nav-icon { font-size: 31rpx; font-weight: 500; line-height: 1.1; }
.nav-label { font-size: 20rpx; font-weight: 600; line-height: 1.2; }
