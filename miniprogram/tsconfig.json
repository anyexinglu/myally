{
  "compilerOptions": {
    "strict": false,
    "target": "ES2020",
    "module": "CommonJS",
    "types": ["miniprogram-api-typings"],
    "allowJs": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"]
}
