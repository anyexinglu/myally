.chat-page { background: #fff; box-sizing: border-box; min-height: 100vh; position: relative; }
.chat-bg {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-size: cover; background-position: center; opacity: 0.25;
  pointer-events: none; z-index: 0;
}
.chat-bg-fortune {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-image: url(../../assets/images/suyan-bg.jpg);
  background-size: cover; background-position: center; opacity: 0.25;
  pointer-events: none; z-index: 0;
}
.skill-avatar { background: #4ecfa5 !important; font-size: 30rpx !important; }
.chat-head { align-items: center; box-sizing: border-box; display: flex; gap: 22rpx; height: 124rpx; justify-content: flex-start; padding: 18rpx 230rpx 10rpx 42rpx; }
.brand-lockup { flex: 0 0 auto; }
.brand { color: #202725; display: block; font-size: 39rpx; font-weight: 760; letter-spacing: -1rpx; }
.brand-subtitle { color: #a0aaa7; display: block; font-size: 15rpx; font-weight: 650; letter-spacing: 3rpx; margin-top: 4rpx; }
.skill-exit { align-items: center; background: #f2f8f5; border-radius: 50%; color: #65736e; display: flex; flex: 0 0 48rpx; font-size: 24rpx; height: 48rpx; justify-content: center; margin-left: auto; }
.mode-control { align-items: center; background: #f2f8f5; border: 1rpx solid #e1eee9; border-radius: 999rpx; color: #65736e; display: flex; flex: 0 0 auto; font-size: 20rpx; gap: 9rpx; padding: 10rpx 15rpx; }
.mode-control.temporary { background: #fff7e8; border-color: #f4dfb8; color: #8a6932; }
.mode-dot { background: #4ecfa5; border-radius: 50%; height: 10rpx; width: 10rpx; }
.mode-control.temporary .mode-dot { background: #e3a84f; }
.temporary-banner { background: #fff7e8; border: 1rpx solid #f4dfb8; border-radius: 16rpx; color: #8a6932; font-size: 21rpx; margin: -4rpx 40rpx 4rpx; padding: 14rpx 20rpx; text-align: center; }
.message-list { height: calc(100vh - 212rpx); }
.day-label { color: #b6bfbc; font-size: 21rpx; margin: 38rpx 0 46rpx; text-align: center; }
.message-row { align-items: flex-start; display: flex; gap: 18rpx; margin: 0 40rpx 40rpx; }
.message-row.from-user { justify-content: flex-end; margin-left: 130rpx; }
.avatar { align-items: center; background: #4ecfa5; border-radius: 50%; box-shadow: 0 8rpx 22rpx rgba(78,207,165,.18); color: #fff; display: flex; flex: 0 0 68rpx; font-size: 25rpx; font-weight: 700; height: 68rpx; justify-content: center; }
.message-stack { display: flex; flex-direction: column; max-width: 540rpx; }
.bubble { box-sizing: border-box; font-size: 29rpx; line-height: 1.55; }
.ally-bubble { color: #29312f; padding: 6rpx 0; }
.user-bubble { background: #4ecfa5; border-radius: 27rpx 27rpx 8rpx 27rpx; box-shadow: 0 10rpx 25rpx rgba(78,207,165,.15); color: #fff; min-width: 100rpx; padding: 21rpx 26rpx; }
.message-text { display: block; word-break: break-all; }
.message-image { border-radius: 18rpx; display: block; height: 280rpx; margin-bottom: 12rpx; width: 360rpx; }
.memory-note { color: #b1bab7; font-size: 20rpx; line-height: 1.5; margin-top: 6rpx; }
.warning-note { color: #b07c40; }
.sending-mark { color: rgba(255,255,255,.72); font-size: 19rpx; margin-top: 7rpx; }
.failed-actions { align-items: center; display: flex; gap: 18rpx; justify-content: flex-end; margin-top: 7rpx; }
.failed-mark { color: #cc6b62; font-size: 20rpx; }
.retry-link { color: #299b78; font-size: 20rpx; font-weight: 650; }
.thinking-row { align-items: center; display: flex; gap: 18rpx; margin: 0 40rpx 30rpx; }
.small-avatar { flex-basis: 52rpx; font-size: 20rpx; height: 52rpx; width: 52rpx; }
.thinking { align-items: center; display: flex; gap: 8rpx; padding: 14rpx 0; }
.thinking text { background: #96ded0; border-radius: 50%; height: 9rpx; width: 9rpx; }
.scroll-spacer { height: 360rpx; }
.composer-zone { bottom: 0; left: 30rpx; position: fixed; right: 30rpx; z-index: 60; }
.selected-image { background: #fff; border: 1rpx solid #e7efec; border-radius: 22rpx; box-shadow: 0 10rpx 30rpx rgba(31,72,59,.08); height: 150rpx; margin: 0 0 12rpx 14rpx; padding: 10rpx; position: relative; width: 150rpx; }
.selected-image image { border-radius: 15rpx; height: 100%; width: 100%; }
.remove-image { align-items: center; background: #26312d; border: 4rpx solid #fff; border-radius: 50%; color: #fff; display: flex; font-size: 25rpx; height: 38rpx; justify-content: center; position: absolute; right: -10rpx; top: -10rpx; width: 38rpx; }
/* 聊天输入栏 — 微信白色模式 */
.composer-zone { background: #ededed; }
.chat-composer {
  display: flex; align-items: center; gap: 12rpx; padding: 10rpx 28rpx 20rpx;
  background: #ededed;
}
/* 切换键 — 绿色圆圈（唯一配色差异） */
.toggle-key { flex: 0 0 54rpx; width: 54rpx; height: 54rpx; border-radius: 50%; border: 3rpx solid #4ecfa5; display: flex; align-items: center; justify-content: center; background: transparent; }
.toggle-key .spk { position: relative; width: 24rpx; height: 20rpx; }
.toggle-key .spk::before { content: ''; position: absolute; left: 0; top: 2rpx; width: 0; height: 0; border: 9rpx solid transparent; border-right: 13rpx solid #4ecfa5; }
.toggle-key .spk::after { content: ''; position: absolute; left: 11rpx; top: 2rpx; width: 10rpx; height: 16rpx; border: 3rpx solid #4ecfa5; border-radius: 0 6rpx 6rpx 0; border-left: none; }
.toggle-key .kbi { width: 24rpx; display: flex; flex-direction: column; gap: 4rpx; align-items: center; }
.toggle-key .kbi span { display: block; height: 3rpx; background: #4ecfa5; border-radius: 1.5rpx; }
.toggle-key .kbi span:nth-child(1) { width: 100%; }
.toggle-key .kbi span:nth-child(2) { width: 100%; }
.toggle-key .kbi span:nth-child(3) { width: 70%; }

/* 输入框 — 白色圆角 */
.chat-input { flex: 1; height: 68rpx; background: #fff; border-radius: 34rpx; padding: 0 28rpx; font-size: 26rpx; color: #333; }
.chat-placeholder { color: #bbb; }

/* 按住说话 — 白色按钮 */
.voice-hold { flex: 1; height: 68rpx; background: #fff; border-radius: 34rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; color: #333; letter-spacing: 2rpx; }
.voice-hold:active { background: #f5f5f5; }

/* 输入框内嵌麦克风 */
.input-mic-wrap { position: relative; display: inline-flex; align-items: center; }
.input-mic { width: 30rpx; height: 30rpx; border: 3rpx solid #999; border-radius: 4rpx; border-bottom: none; position: relative; flex-shrink: 0; }
.input-mic::after { content: ''; position: absolute; bottom: -8rpx; left: 8rpx; width: 8rpx; height: 10rpx; background: #999; border-radius: 0 0 3rpx 3rpx; }

/* 表情 + 加号 — 微信风格黑色圆圈 */
.icon-emoji { flex: 0 0 54rpx; width: 54rpx; height: 54rpx; border-radius: 50%; border: 3rpx solid #333; display: flex; align-items: center; justify-content: center; color: #333; font-size: 26rpx; }
.icon-plus { flex: 0 0 54rpx; width: 54rpx; height: 54rpx; border-radius: 50%; border: 3rpx solid #333; display: flex; align-items: center; justify-content: center; color: #333; font-size: 36rpx; font-weight: 300; }

/* 录音覆盖层 — 微信白色模式 */
.recording-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.18); z-index: 200;
  display: flex; flex-direction: column; align-items: center;
}
.voice-bubble {
  background: #4ecfa5; border-radius: 28rpx; padding: 32rpx 40rpx;
  position: relative; margin-top: 220rpx; margin-bottom: 20rpx;
}
.bubble-tail {
  position: absolute; bottom: -16rpx; left: 60rpx;
  width: 0; height: 0; border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent; border-top: 20rpx solid #4ecfa5;
}
.wave-dense { display: flex; align-items: center; gap: 4rpx; height: 68rpx; }
.wave-bar { width: 5rpx; background: rgba(0,0,0,0.4); border-radius: 2.5rpx; }
.rec-dur { font-size: 56rpx; font-weight: 700; color: #333; margin-top: 12rpx; letter-spacing: 1rpx; }

/* 底部面板 — 微信结构 */
.rec-arc-area {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 30rpx 20rpx 40rpx; background: #ededed;
  display: flex; align-items: flex-start; justify-content: space-between;
}
.arc-btn { padding: 16rpx 20rpx; border-radius: 10rpx; font-size: 22rpx; color: #555; background: #fff; white-space: nowrap; margin-top: 40rpx; }
.arc-btn.hl { background: #e8e8e8; color: #333; }
.arc-send-wrap { flex: 1; text-align: center; margin: 0 8rpx; }
.arc-send { display: inline-block; background: #fff; border-radius: 120rpx 120rpx 0 0; padding: 30rpx 60rpx 20rpx; font-size: 28rpx; color: #333; font-weight: 600; letter-spacing: 2rpx; min-width: 240rpx; }
.arc-send.dim { opacity: 0.3; }
.arc-trans { font-size: 22rpx; color: #999; padding: 16rpx 16rpx; white-space: nowrap; margin-top: 40rpx; }

/* 语音按钮 */
.voice-button {
  align-items: center;
  background: #4ecfa5;
  border-radius: 50%;
  color: #fff;
  display: flex;
  flex: 0 0 72rpx;
  font-size: 36rpx;
  height: 72rpx;
  justify-content: center;
  width: 72rpx;
}
.voice-button.hidden { display: none; }
.voice-button:active { transform: scale(0.92); }

/* 录音状态栏（微信风格） */
.recording-bar {
  align-items: center;
  background: #f2f2f2;
  border-radius: 999rpx;
  display: flex;
  justify-content: center;
  min-height: 96rpx;
  padding: 7rpx 24rpx;
}
.recording-inner {
  align-items: center;
  display: flex;
  gap: 16rpx;
}
.recording-mic {
  align-items: center;
  background: #4ecfa5;
  border-radius: 50%;
  display: flex;
  height: 72rpx;
  justify-content: center;
  width: 72rpx;
}
.recording-mic.cancel {
  background: #ff4d4d;
}
.recording-icon {
  font-size: 36rpx;
}
.recording-label {
  color: #26312d;
  font-size: 28rpx;
}
/* 微信原生录音界面 */
.recording-overlay {
  position: fixed; bottom: 0; left: 0; right: 0; top: 0;
  background: rgba(0,0,0,0.5); z-index: 200;
  display: flex; flex-direction: column; align-items: center;
  padding-top: 160rpx;
}
.voice-bubble {
  background: #4ecfa5; border-radius: 24rpx; padding: 28rpx 32rpx;
  position: relative; margin-bottom: 20rpx;
}
.bubble-tail {
  position: absolute; bottom: -12rpx; left: 40rpx;
  width: 0; height: 0; border-left: 14rpx solid transparent;
  border-right: 14rpx solid transparent; border-top: 16rpx solid #4ecfa5;
}
.wave-dense { display: flex; align-items: center; gap: 3rpx; height: 80rpx; }
.wave-dense-bar { width: 4rpx; background: #fff; border-radius: 2rpx; }
.rec-dur { font-size: 52rpx; font-weight: 700; color: #fff; margin-bottom: 60rpx; }
.rec-arc-area {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; justify-content: space-between; align-items: flex-end;
  padding: 20rpx 24rpx 60rpx;
}
.arc-btn {
  padding: 16rpx 24rpx; border-radius: 12rpx;
  font-size: 26rpx; color: #ccc; background: rgba(255,255,255,0.15);
}
.arc-send {
  background: #4ecfa5; color: #fff; font-size: 30rpx; font-weight: 600;
  padding: 20rpx 60rpx; border-radius: 40rpx;
}
.recording-time {
  color: #999;
  font-size: 24rpx;
}

/* 流式光标闪烁 */
.streaming-cursor {
  animation: blink 0.8s step-end infinite;
  color: #4ecfa5;
}
@keyframes blink {
  50% { opacity: 0; }
}
