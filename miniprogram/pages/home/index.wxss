.chat-page { background: #fff; box-sizing: border-box; min-height: 100vh; position: relative; }
.chat-bg {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background-size: cover; background-position: center; opacity: 0.15;
  pointer-events: none; z-index: 0;
}
.chat-head { align-items: center; box-sizing: border-box; display: flex; gap: 22rpx; height: 124rpx; justify-content: flex-start; padding: 18rpx 230rpx 10rpx 42rpx; }
.brand-lockup { flex: 0 0 auto; }
.brand { color: #202725; display: block; font-size: 39rpx; font-weight: 760; letter-spacing: -1rpx; }
.brand-subtitle { color: #a0aaa7; display: block; font-size: 15rpx; font-weight: 650; letter-spacing: 3rpx; margin-top: 4rpx; }
.mode-control { align-items: center; background: #f2f8f5; border: 1rpx solid #e1eee9; border-radius: 999rpx; color: #65736e; display: flex; flex: 0 0 auto; font-size: 20rpx; gap: 9rpx; padding: 10rpx 15rpx; }
.mode-control.temporary { background: #fff7e8; border-color: #f4dfb8; color: #8a6932; }
.mode-dot { background: #4ecfa5; border-radius: 50%; height: 10rpx; width: 10rpx; }
.mode-control.temporary .mode-dot { background: #e3a84f; }
.temporary-banner { background: #fff7e8; border: 1rpx solid #f4dfb8; border-radius: 16rpx; color: #8a6932; font-size: 21rpx; margin: -4rpx 40rpx 4rpx; padding: 14rpx 20rpx; text-align: center; }
.message-list { height: calc(100vh - 212rpx); }
.day-label { color: #b6bfbc; font-size: 21rpx; margin: 38rpx 0 46rpx; text-align: center; }
.message-row { align-items: flex-start; display: flex; gap: 18rpx; margin: 0 40rpx 40rpx; }
.message-row.from-user { justify-content: flex-end; margin-left: 130rpx; }
.avatar { align-items: center; background: #4ecfa5; border-radius: 50%; box-shadow: 0 8rpx 22rpx rgba(78,207,165,.18); color: #fff; display: flex; flex: 0 0 68rpx; font-size: 25rpx; font-weight: 700; height: 68rpx; justify-content: center; }
.message-stack { display: flex; flex-direction: column; max-width: 540rpx; }
.bubble { box-sizing: border-box; font-size: 29rpx; line-height: 1.55; }
.ally-bubble { color: #29312f; padding: 6rpx 0; }
.user-bubble { background: #4ecfa5; border-radius: 27rpx 27rpx 8rpx 27rpx; box-shadow: 0 10rpx 25rpx rgba(78,207,165,.15); color: #fff; min-width: 100rpx; padding: 21rpx 26rpx; }
.message-text { display: block; word-break: break-all; }
.message-image { border-radius: 18rpx; display: block; height: 280rpx; margin-bottom: 12rpx; width: 360rpx; }
.memory-note { color: #b1bab7; font-size: 20rpx; line-height: 1.5; margin-top: 6rpx; }
.warning-note { color: #b07c40; }
.sending-mark { color: rgba(255,255,255,.72); font-size: 19rpx; margin-top: 7rpx; }
.failed-actions { align-items: center; display: flex; gap: 18rpx; justify-content: flex-end; margin-top: 7rpx; }
.failed-mark { color: #cc6b62; font-size: 20rpx; }
.retry-link { color: #299b78; font-size: 20rpx; font-weight: 650; }
.thinking-row { align-items: center; display: flex; gap: 18rpx; margin: 0 40rpx 30rpx; }
.small-avatar { flex-basis: 52rpx; font-size: 20rpx; height: 52rpx; width: 52rpx; }
.thinking { align-items: center; display: flex; gap: 8rpx; padding: 14rpx 0; }
.thinking text { background: #96ded0; border-radius: 50%; height: 9rpx; width: 9rpx; }
.scroll-spacer { height: 360rpx; }
.composer-zone { bottom: 0; left: 30rpx; position: fixed; right: 30rpx; z-index: 60; }
.selected-image { background: #fff; border: 1rpx solid #e7efec; border-radius: 22rpx; box-shadow: 0 10rpx 30rpx rgba(31,72,59,.08); height: 150rpx; margin: 0 0 12rpx 14rpx; padding: 10rpx; position: relative; width: 150rpx; }
.selected-image image { border-radius: 15rpx; height: 100%; width: 100%; }
.remove-image { align-items: center; background: #26312d; border: 4rpx solid #fff; border-radius: 50%; color: #fff; display: flex; font-size: 25rpx; height: 38rpx; justify-content: center; position: absolute; right: -10rpx; top: -10rpx; width: 38rpx; }
.chat-composer { align-items: center; background: rgba(255,255,255,.98); border: 1rpx solid #e6efeb; border-radius: 999rpx; box-shadow: 0 12rpx 44rpx rgba(30,77,61,.105); box-sizing: border-box; display: flex; gap: 8rpx; min-height: 96rpx; padding: 7rpx 9rpx 7rpx 13rpx; }
.attach-button { align-items: center; color: #42c99d; display: flex; flex: 0 0 64rpx; height: 64rpx; justify-content: center; }
.attach-icon { border: 3rpx solid #4ecfa5; border-radius: 50%; font-size: 33rpx; font-weight: 300; height: 39rpx; line-height: 36rpx; text-align: center; width: 39rpx; }
.chat-input { color: #26312d; flex: 1; font-size: 28rpx; height: 78rpx; }
.chat-placeholder { color: #b0b9b6; }
.send-button { align-items: center; background: #dce5e2 !important; border-radius: 50% !important; box-shadow: none; color: #fff !important; display: flex; flex: 0 0 72rpx; font-size: 41rpx !important; font-weight: 350; height: 72rpx; justify-content: center; line-height: 1 !important; margin: 0; padding: 0 0 7rpx; width: 72rpx; }
.send-button.ready { background: #4ecfa5 !important; box-shadow: 0 8rpx 20rpx rgba(78,207,165,.25); }
.send-button[disabled] { opacity: 1; }

/* 语音按钮 */
.voice-button {
  align-items: center;
  background: #4ecfa5;
  border-radius: 50%;
  color: #fff;
  display: flex;
  flex: 0 0 72rpx;
  font-size: 36rpx;
  height: 72rpx;
  justify-content: center;
  width: 72rpx;
}
.voice-button.hidden { display: none; }
.voice-button:active { transform: scale(0.92); }

/* 录音状态栏（微信风格） */
.recording-bar {
  align-items: center;
  background: #f2f2f2;
  border-radius: 999rpx;
  display: flex;
  justify-content: center;
  min-height: 96rpx;
  padding: 7rpx 24rpx;
}
.recording-inner {
  align-items: center;
  display: flex;
  gap: 16rpx;
}
.recording-mic {
  align-items: center;
  background: #4ecfa5;
  border-radius: 50%;
  display: flex;
  height: 72rpx;
  justify-content: center;
  width: 72rpx;
}
.recording-mic.cancel {
  background: #ff4d4d;
}
.recording-icon {
  font-size: 36rpx;
}
.recording-label {
  color: #26312d;
  font-size: 28rpx;
}
.recording-time {
  color: #999;
  font-size: 24rpx;
}

/* 流式光标闪烁 */
.streaming-cursor {
  animation: blink 0.8s step-end infinite;
  color: #4ecfa5;
}
@keyframes blink {
  50% { opacity: 0; }
}
