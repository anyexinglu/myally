<view class="chat-page" style="padding-top: {{headerTop}}px;">
  <view wx:if="{{activeSkillBackground}}" class="chat-bg"></view>
  <view wx:if="{{activeSkill && activeSkill.id === 'fortune-teller'}}" class="chat-bg-fortune"></view>
  <view class="chat-head">
    <view class="brand-lockup">
      <text class="brand">{{activeSkill ? activeSkill.name : '我在'}}</text>
      <text class="brand-subtitle">{{activeSkill ? '观微阁主' : 'MYALLY'}}</text>
    </view>
    <view wx:if="{{activeSkill}}" class="skill-exit" bindtap="exitSkill">✕</view>
    <view class="mode-control {{temporary ? 'temporary' : ''}}" bindtap="toggleTemporary">
      <text class="mode-dot"></text>
      <text>{{temporary ? '临时对话' : '私密对话'}}</text>
    </view>
  </view>

  <view wx:if="{{temporary}}" class="temporary-banner">临时对话 · 不读取、不形成长期记忆</view>

  <scroll-view class="message-list" scroll-y enhanced show-scrollbar="{{false}}" scroll-with-animation scroll-into-view="{{anchor}}">
    <view class="day-label">今天</view>
    <block wx:for="{{messages}}" wx:key="id">
      <view id="message-{{item.id}}" class="message-row {{item.role === 'user' ? 'from-user' : 'from-ally'}}">
        <view wx:if="{{item.role === 'assistant'}}" class="avatar {{activeSkill ? 'skill-avatar' : ''}}">{{activeSkill && activeSkill.emoji || '我'}}</view>
        <view class="message-stack">
          <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'ally-bubble'}}">
            <image wx:if="{{item.type === 'image' && item.fileId}}" class="message-image" src="{{item.fileId}}" mode="aspectFill" />
            <text wx:if="{{item.text}}" class="message-text">{{item.text}}</text>
            <view wx:if="{{item.pending}}" class="sending-mark">发送中…</view>
          </view>
          <view wx:if="{{item.failed}}" class="failed-actions">
            <text class="failed-mark">发送失败</text>
            <text class="retry-link" data-id="{{item.id}}" bindtap="retrySend">重试</text>
          </view>
          <text wx:elif="{{item.role === 'assistant' && item.memoryCount}}" class="memory-note">使用了 {{item.memoryCount}} 条个人记忆</text>
          <text wx:elif="{{item.role === 'assistant' && item.memoryStatus === 'failed'}}" class="memory-note warning-note">本次记忆整理失败，不影响当前回答</text>
          <text wx:elif="{{item.role === 'assistant' && item.toolCalls.length}}" class="memory-note">已使用受控工具完成核验</text>
          <text wx:elif="{{item.role === 'assistant' && item.id === 'welcome'}}" class="memory-note">内容经你的私密账号隔离保存</text>
        </view>
      </view>
    </block>
    <view wx:if="{{sending}}" class="thinking-row"><view class="avatar small-avatar">我</view><view class="thinking"><text></text><text></text><text></text></view></view>
    <view class="scroll-spacer"></view>
  </scroll-view>

  <view class="composer-zone">
    <view wx:if="{{selectedImage}}" class="selected-image"><image src="{{selectedImage}}" mode="aspectFill" /><view class="remove-image" bindtap="clearImage">×</view></view>
    
    <!-- 录音状态（微信风格全屏覆盖） -->
    <view wx:if="{{recording}}" class="recording-overlay" bindtap="onRecordingTap">
      <view class="rec-top">
        <view class="rec-btn cancel-btn" bindtap="cancelRecording">取消</view>
        <view class="rec-btn trans-btn">转文字</view>
      </view>
      <view class="rec-center">
        <view class="waveform">
          <view wx:for="{{5}}" wx:key="*this" class="wave-bar" style="animation-delay: -{{item * 0.15}}s"></view>
        </view>
        <text class="rec-dur">{{recordingDuration}}″</text>
      </view>
      <view class="rec-bottom {{swipeUp ? 'cancel' : ''}}">
        <view class="rec-send-arc">
          <text class="rec-send-text">{{swipeUp ? '松开取消' : '松开 发送'}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="chat-composer">
      <view class="attach-button" bindtap="chooseImage"><text class="attach-icon">＋</text></view>
      <!-- 语音模式：按住说话按钮 -->
      <view wx:if="{{voiceMode}}" class="voice-hold-btn" bindtouchstart="onVoiceStart" bindtouchend="onVoiceEnd" bindtouchmove="onVoiceMove">
        <text class="voice-hold-text">按住 说话</text>
      </view>
      <!-- 键盘模式：文本输入框 -->
      <input wx:else class="chat-input" maxlength="2000" confirm-type="send" placeholder="{{temporary ? '临时说说…' : '跟我说说…'}}" placeholder-class="chat-placeholder" value="{{text}}" bindinput="onText" bindconfirm="send" />
      <!-- 语音/键盘切换 -->
      <view class="voice-toggle" bindtap="toggleVoiceMode">
        <text class="voice-toggle-icon">{{voiceMode ? '⌨' : '🎤'}}</text>
      </view>
      <button class="send-button {{text || selectedImage ? 'ready' : ''}}" disabled="{{sending || (!text && !selectedImage)}}" bindtap="send">↑</button>
    </view>
  </view>
</view>
