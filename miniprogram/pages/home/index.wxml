<view class="chat-page">
  <view class="chat-head">
    <view><text class="brand">我在</text><text class="brand-subtitle">MYALLY</text></view>
    <view class="presence"><text class="sun">✣</text></view>
  </view>

  <scroll-view class="message-list" scroll-y enhanced show-scrollbar="{{false}}" scroll-with-animation scroll-into-view="{{anchor}}">
    <view class="day-label">今天</view>
    <block wx:for="{{messages}}" wx:key="id">
      <view id="message-{{item.id}}" class="message-row {{item.role === 'user' ? 'from-user' : 'from-ally'}}">
        <view wx:if="{{item.role === 'assistant'}}" class="avatar">我</view>
        <view class="message-stack">
          <view class="bubble {{item.role === 'user' ? 'user-bubble' : 'ally-bubble'}}">
            <image wx:if="{{item.type === 'image' && item.fileId}}" class="message-image" src="{{item.fileId}}" mode="aspectFill" />
            <text wx:if="{{item.text}}" class="message-text">{{item.text}}</text>
            <view wx:if="{{item.pending}}" class="sending-mark">发送中…</view>
          </view>
          <text wx:if="{{item.failed}}" class="failed-mark">发送失败</text>
          <text wx:elif="{{item.role === 'assistant' && item.id === 'welcome'}}" class="memory-note">刚刚 · 你发送的内容会保存到私密空间</text>
        </view>
      </view>
    </block>
    <view wx:if="{{sending}}" class="thinking-row"><view class="avatar small-avatar">我</view><view class="thinking"><text></text><text></text><text></text></view></view>
    <view class="scroll-spacer"></view>
  </scroll-view>

  <view class="composer-zone">
    <view wx:if="{{selectedImage}}" class="selected-image"><image src="{{selectedImage}}" mode="aspectFill" /><view class="remove-image" bindtap="clearImage">×</view></view>
    <view class="chat-composer">
      <view class="attach-button" bindtap="chooseImage"><text class="attach-icon">＋</text></view>
      <input class="chat-input" maxlength="2000" confirm-type="send" placeholder="跟我说说…" placeholder-class="chat-placeholder" value="{{text}}" bindinput="onText" bindconfirm="send" />
      <button class="send-button {{text || selectedImage ? 'ready' : ''}}" disabled="{{sending || (!text && !selectedImage)}}" bindtap="send">↑</button>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item active"><text class="nav-icon">⌂</text><text class="nav-label">首页</text></view>
    <view class="nav-item" bindtap="goMine"><text class="nav-icon">▤</text><text class="nav-label">我的</text></view>
    <view class="nav-item" bindtap="goWatch"><text class="nav-icon">◎</text><text class="nav-label">守望</text></view>
  </view>
</view>
