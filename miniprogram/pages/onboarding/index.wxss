.container {
  display: flex;
  flex-direction: column;
  padding: 32rpx 24rpx;
  min-height: 100vh;
  background: #f5f7fa;
}
.progress-bar {
  height: 6rpx;
  background: #e0e0e0;
  border-radius: 3rpx;
  margin-bottom: 8rpx;
}
.progress-fill {
  height: 100%;
  background: #07c160;
  border-radius: 3rpx;
  transition: width 0.3s;
}
.step-hint {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-bottom: 32rpx;
}
.question-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  flex: 1;
}
.question-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}
.option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background: #fafafa;
}
.option-item.selected {
  border-color: #07c160;
  background: #07c160;
  color: #fff;
}
.option-label {
  font-size: 28rpx;
  color: #333;
}
.check-mark {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}
.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 32rpx;
  padding-bottom: 48rpx;
}
.btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
}
.btn-prev {
  background: #fff;
  color: #666;
  border: 2rpx solid #ddd;
}
.btn-next {
  background: #07c160;
  color: #fff;
}
.btn-next.disabled {
  background: #ccc;
}
