.container { padding: 32rpx; background: #f5f7fa; min-height: 100vh; }
.card { background: #fff; border-radius: 16rpx; padding: 32rpx; }
.title { font-size: 34rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 16rpx; }
.desc { font-size: 26rpx; color: #666; line-height: 1.6; display: block; margin-bottom: 32rpx; }
.switch-row { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; }
.switch-label { font-size: 28rpx; color: #333; }
.debug-actions { margin-top: 32rpx; padding-top: 32rpx; border-top: 2rpx solid #eee; }
.btn { height: 88rpx; line-height: 88rpx; border-radius: 12rpx; font-size: 30rpx; background: #07c160; color: #fff; border: none; margin-bottom: 16rpx; }
.hint { font-size: 24rpx; color: #999; line-height: 1.5; display: block; }
