<view class="container">
  <view class="page-head mine-head">
    <text class="eyebrow">MY SPACE</text>
    <text class="page-title">我的空间</text>
    <text class="page-subtitle">查看它记住了什么，也可以随时删除。所有内容按微信账号隔离。</text>
  </view>

  <view class="section-heading"><text class="section-title">个人记忆</text><text class="hint">{{memories.length}} 个版本</text></view>
  <view wx:if="{{!loading && !error && memories.length === 0}}" class="memory-empty card">
    <text class="hint">还没有长期记忆。你可以在对话中明确说出偏好或目标。</text>
  </view>
  <view class="memory-card card" wx:for="{{memories}}" wx:key="id">
    <view class="row between"><text class="tag">{{item.type}}</text><text class="visibility">{{item.status === 'superseded' ? '已更新' : '已确认'}}</text></view>
    <text class="memory-value">{{item.value}}</text>
    <text wx:if="{{item.status === 'superseded'}}" class="hint">有效至：{{item.validTo}}</text>
    <view class="record-footer"><text class="hint">来源：{{item.observedAt || '用户明确表达'}}</text><button class="delete-button" data-id="{{item.id}}" bindtap="removeMemory">删除记忆</button></view>
  </view>

  <view class="section-heading record-heading"><text class="section-title">原有记录</text><text class="hint">{{entries.length}} 条</text></view>

  <view class="record-summary">
    <view class="summary-count"><text class="count-number">{{entries.length}}</text><text class="count-label">条记录</text></view>
    <view class="summary-privacy"><text class="lock-mark">◇</text>原文仅自己可见</view>
  </view>

  <view wx:if="{{loading}}" class="state-card card"><view class="state-dot"></view><text class="hint">正在加载记录…</text></view>
  <view wx:if="{{error}}" class="state-card card error">{{error}}</view>
  <view wx:if="{{!loading && !error && entries.length === 0}}" class="empty-state card">
    <view class="empty-icon">＋</view>
    <view class="section-title">还没有原有记录</view>
    <text class="hint">从首页写下一件此刻想留下的事吧。</text>
    <button class="empty-action" bindtap="goHome">去记录</button>
  </view>

  <view class="record-card card" wx:for="{{entries}}" wx:key="id">
    <view class="row between">
      <text class="tag">{{item.type === 'text' ? '文字' : (item.type === 'image' ? '图片' : '语音')}}</text>
      <text class="visibility {{item.visibility === 'shared' ? 'shared' : ''}}">{{item.visibility === 'shared' ? '已共享摘要' : '仅自己'}}</text>
    </view>
    <text wx:if="{{item.type === 'text'}}" class="content">{{item.text}}</text>
    <image wx:elif="{{item.type === 'image'}}" class="media" src="{{item.fileId}}" mode="aspectFill" />
    <button wx:else class="voice-player" data-file="{{item.fileId}}" bindtap="play"><text class="play-icon">▶</text><text>播放语音</text></button>
    <view wx:if="{{item.summary}}" class="shared-summary"><text class="summary-label">共享摘要</text><text>{{item.summary}}</text></view>
    <view class="record-footer">
      <text class="hint">{{item.createdAt || '已安全保存'}}</text>
      <button class="delete-button" data-id="{{item.id}}" bindtap="remove">删除</button>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-item" bindtap="goHome"><text class="nav-icon">⌂</text><text class="nav-label">首页</text></view>
    <view class="nav-item active"><text class="nav-icon">▤</text><text class="nav-label">我的</text></view>
    <view class="nav-item" bindtap="goWatch"><text class="nav-icon">◎</text><text class="nav-label">守望</text></view>
  </view>
</view>
