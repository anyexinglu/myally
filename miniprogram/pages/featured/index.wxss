.segment {
  background: #eaf3ef;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  margin-bottom: 24rpx;
  padding: 8rpx;
}

.segment-item {
  border-radius: 999rpx;
  color: #5d6b66;
  flex: 1;
  font-size: 30rpx;
  font-weight: 650;
  padding: 18rpx 0;
  text-align: center;
}

.segment-item.active {
  background: #ffffff;
  box-shadow: 0 6rpx 18rpx rgba(34, 83, 68, .08);
  color: #1d2925;
}

.section-hint { display: block; margin: 0 4rpx 20rpx; }

.skills-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.skill-card {
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  margin-bottom: 0;
  padding: 28rpx 24rpx;
  width: calc(50% - 10rpx);
}

.skill-emoji {
  background: #eaf9f3;
  border-radius: 32rpx;
  font-size: 52rpx;
  height: 96rpx;
  line-height: 96rpx;
  margin-bottom: 18rpx;
  text-align: center;
  width: 96rpx;
}

.skill-name { color: #1d2925; font-size: 31rpx; font-weight: 720; }

.skill-liner {
  color: #44524c;
  display: block;
  font-size: 25rpx;
  line-height: 1.55;
  margin-top: 10rpx;
  min-height: 78rpx;
}

.skill-tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-top: 16rpx; }

.skill-tag {
  background: #f0f7f4;
  border-radius: 999rpx;
  color: #278f6c;
  font-size: 21rpx;
  padding: 6rpx 18rpx;
}

.solution-head { align-items: center; display: flex; gap: 20rpx; justify-content: space-between; }
.solution-title-wrap { flex: 1; }
.solution-title { color: #1d2925; display: block; font-size: 30rpx; font-weight: 680; line-height: 1.45; }
.solution-audience { color: #278f6c; display: block; font-size: 23rpx; margin-top: 8rpx; }
.expand-mark { color: #2aaa80; flex: 0 0 auto; font-size: 24rpx; }

.solution-steps { border-top: 1rpx solid #edf2f0; margin-top: 22rpx; padding-top: 20rpx; }
.step-row { display: flex; gap: 16rpx; margin-bottom: 18rpx; }
.step-row:last-child { margin-bottom: 0; }
.step-index {
  background: #eaf9f3;
  border-radius: 50%;
  color: #278f6c;
  flex: 0 0 42rpx;
  font-size: 23rpx;
  font-weight: 650;
  height: 42rpx;
  line-height: 42rpx;
  margin-top: 5rpx;
  text-align: center;
}
.step-text { color: #33403b; flex: 1; font-size: 27rpx; line-height: 1.65; }

.channel-chips {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.channel-chip {
  background: #f0f7f4;
  border-radius: 999rpx;
  color: #5d6b66;
  flex: 0 0 auto;
  font-size: 25rpx;
  font-weight: 600;
  padding: 12rpx 28rpx;
}

.channel-chip.active {
  background: #2aaa80;
  color: #ffffff;
}

.feed-head { align-items: center; display: flex; gap: 20rpx; justify-content: space-between; }
.feed-title-wrap { flex: 1; }
.feed-meta { align-items: center; display: flex; gap: 12rpx; margin-bottom: 8rpx; }
.feed-date { color: #278f6c; font-size: 23rpx; }
.feed-private {
  background: #fdf3e3;
  border-radius: 999rpx;
  color: #b07817;
  font-size: 20rpx;
  padding: 3rpx 14rpx;
}
.feed-title { color: #1d2925; display: block; font-size: 29rpx; font-weight: 680; line-height: 1.45; }
.feed-empty { padding: 60rpx 0; text-align: center; }
.feed-content {
  border-top: 1rpx solid #edf2f0;
  color: #33403b;
  font-size: 27rpx;
  line-height: 1.7;
  margin-top: 20rpx;
  padding-top: 18rpx;
  white-space: pre-wrap;
  word-break: break-all;
}
